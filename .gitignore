# ─── TwinCurrent (must never commit) ────────────────────────────────
.twincurrent-build/

# ─── Claude Code (local agent state, permission grants, MCP creds) ──
.claude/

# ─── Environment & secrets ──────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Foundry (contracts/ only — scoped so Next.js paths like web/lib/ aren't matched) ───
contracts/out/
contracts/cache/
contracts/broadcast/
contracts/lib/
contracts/dependencies/
contracts/.foundry/

# ─── Node / Next.js (web/) ──────────────────────────────────────────
node_modules/
.next/
dist/
build/
.vercel/
.turbo/
*.tsbuildinfo
next-env.d.ts

# ─── Logs ───────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Editors / OS ───────────────────────────────────────────────────
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
desktop.ini
