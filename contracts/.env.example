# ─── Carbon DEX deploy + demo env vars ────────────────────────────────────
# Copy this file to .env (gitignored) and fill in real values.
# Forge loads .env automatically when running scripts.

# ─── RPC endpoints ─────────────────────────────────────────────────────────
# Sepolia HTTPS endpoint — get a free one from alchemy.com (Sepolia app).
# Format: https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
SEPOLIA_RPC_URL=

# ─── Deploy.s.sol — single-key deploy ──────────────────────────────────────
# Private key of the wallet that deploys all 6 contracts. Receives DEFAULT_ADMIN_ROLE
# on Credit / Registry / DEX, then grants the operational roles to Regulator + Retirement.
# Same key pays for the Sepolia gas (0.5 ETH covers comfortably).
# Generate via: cast wallet new
PRIVATE_KEY=0x

# Optional: if set, the deployer is admin-only and this address becomes Regulator's
# OPERATOR_ROLE holder (so the deployer key never has to do regulator operations).
# Leave unset for hackathon — defaults to deployer.
# REGULATOR_ADMIN=0x

# ─── Demo.s.sol — multi-key happy flow ─────────────────────────────────────
# After Deploy.s.sol has run + addresses are known, run Demo.s.sol with these:
OPERATOR_PK=0x       # Same as PRIVATE_KEY above (or REGULATOR_ADMIN if set)
COMPANY_A_PK=0x      # cement-mainz.verified-entity.eth
COMPANY_B_PK=0x      # aluminium-bratislava.verified-entity.eth (off-stage actor)

# All three companies need at least 0.05 Sepolia ETH to cover their demo txs.
