# WalletConnect project ID (required for RainbowKit's WalletConnect support).
# Get one at https://cloud.reown.com (formerly cloud.walletconnect.com).
# For local-anvil-only development without WalletConnect, leave unset — the
# fallback in lib/wagmi.ts ("carbon-dex-dev") works for injected wallets only.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Sepolia RPC URL. Use a provider that does NOT cap eth_getLogs block range —
# the server fetches event history via getLogs, and Alchemy free tier caps it
# at 10 blocks (verified). PublicNode (no key, no cap, ~0.2s for 50k range)
# is the default; swap in your own paid endpoint if rate limits bite.
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
