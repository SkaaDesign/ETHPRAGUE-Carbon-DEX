# WalletConnect project ID (required for RainbowKit's WalletConnect support).
# Get one at https://cloud.reown.com (formerly cloud.walletconnect.com).
# For local-anvil-only development without WalletConnect, leave unset — the
# fallback in lib/wagmi.ts ("carbon-dex-dev") works for injected wallets only.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Sepolia RPC URL override. Optional — viem ships a public default.
# Use Alchemy, Infura, or a self-hosted endpoint for production reliability.
NEXT_PUBLIC_SEPOLIA_RPC_URL=
